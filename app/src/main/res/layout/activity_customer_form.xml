<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_page">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close"
            app:tint="@color/text_dark" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tambah_customer"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/spacing_sm" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <!-- Kode Customer -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCode"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/kode_customer"
                    android:inputType="text"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nama Customer -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/nama_customer"
                    android:inputType="textPersonName"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- No HP -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="@string/no_hp"
                    android:inputType="phone"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Alamat -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAddress"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/input_height"
                    android:hint="@string/alamat"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Golongan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/golongan"
                android:textColor="@color/text_dark"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <RadioGroup
                android:id="@+id/rgGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_xxl">

                <RadioButton
                    android:id="@+id/rbUser"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="USER"
                    android:textSize="@dimen/text_body_large"
                    android:buttonTint="@color/primary"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbFreelancer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="FREELANCER"
                    android:textSize="@dimen/text_body_large"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/rbGrosir"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="GROSIR"
                    android:textSize="@dimen/text_body_large"
                    android:buttonTint="@color/primary" />
            </RadioGroup>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.KasirUmkm.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:text="@string/simpan" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
