<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="@dimen/spacing_xl">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/border"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ Tambah Produk Cepat"
        android:textColor="@color/text_dark"
        android:textSize="@dimen/text_headline_medium"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Nama Produk -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilName"
        style="@style/Widget.KasirUmkm.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:hint="Nama Produk (Wajib)"
            android:inputType="textPersonName"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Kode Produk + Scan Icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCode"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCode"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Kode Produk (Opsional)"
                android:inputType="text"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_barcode_scan"
            app:iconTint="@color/primary"
            app:iconSize="24dp"
            app:iconPadding="0dp"
            android:contentDescription="Scan Barcode" />
    </LinearLayout>

    <!-- Satuan & Stok -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUnit"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUnit"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Satuan (e.g. pcs)"
                android:inputType="text"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilStock"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStock"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Stok Awal (Opsional)"
                android:inputType="number"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Harga Modal & Harga Jual USER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCostPrice"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:prefixText="Rp "
            app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix.Medium">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCostPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:hint="Harga Modal"
                android:inputType="numberDecimal"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPriceUser"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:prefixText="Rp "
            app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix.Medium">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPriceUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:hint="Harga USER (Wajib)"
                android:inputType="numberDecimal"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Harga Freelancer & Harga Grosir -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_lg">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPriceFreelancer"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:prefixText="Rp "
            app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix.Medium">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPriceFreelancer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:hint="Harga Freelancer (Opsional)"
                android:inputType="numberDecimal"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPriceGrosir"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:prefixText="Rp "
            app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix.Medium">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPriceGrosir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:hint="Harga Grosir (Opsional)"
                android:inputType="numberDecimal"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_large"
        android:text="Simpan &amp; Pilih ke Keranjang"
        android:textAllCaps="false"
        android:textSize="@dimen/text_title_medium"
        app:backgroundTint="@color/primary"
        app:cornerRadius="@dimen/button_radius"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Batal"
        android:textAllCaps="false"
        android:textColor="@color/text_gray"
        android:textSize="@dimen/text_body_large" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

</LinearLayout>
