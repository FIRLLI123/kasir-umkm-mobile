<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/border_light"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Invoice Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Transaksi"
                android:textColor="@color/text_light"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvSheetInvoice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INV/xxxx/xxxx"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvSheetStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="SUKSES"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_success" />
    </RelativeLayout>

    <!-- Scrollable Receipt Content (To prevent screen cut-off on small devices) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxHeight="320dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="16dp"
            android:elevation="1dp">

            <!-- Transaction Info -->
            <TextView
                android:id="@+id/tvSheetDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tanggal: -"
                android:textColor="@color/text_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSheetCustomer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pelanggan: -"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvSheetPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pembayaran: -"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <!-- Receipt Divider -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="----------------------------------------"
                android:textColor="@color/border_light"
                android:gravity="center"
                android:layout_marginVertical="8dp" />

            <!-- Dynamic Items Container -->
            <LinearLayout
                android:id="@+id/layoutSheetItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Receipt Divider -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="----------------------------------------"
                android:textColor="@color/border_light"
                android:gravity="center"
                android:layout_marginVertical="8dp" />

            <!-- Calculations Rows -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subtotal"
                    android:textColor="@color/text_light"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvSheetSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Rp 0"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diskon"
                    android:textColor="@color/text_light"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvSheetDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Rp 0"
                    android:textColor="@color/danger_red"
                    android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL TAGIHAN"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSheetGrandTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Rp 0"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Tunai & Kembalian -->
            <RelativeLayout
                android:id="@+id/layoutSheetCashDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:id="@+id/rowSheetPaid">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bayar (Tunai)"
                        android:textColor="@color/text_light"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvSheetPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Rp 0"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/rowSheetPaid">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kembalian"
                        android:textColor="@color/text_light"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/tvSheetChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Rp 0"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp" />
                </RelativeLayout>
            </RelativeLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="20dp" />

    <!-- Cetak Ulang Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSheetReprint"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Cetak Ulang Struk"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:backgroundTint="@color/primary"
        android:insetBottom="0dp"
        android:insetTop="0dp" />

    <!-- Void Info Section (shown only for voided transactions) -->
    <LinearLayout
        android:id="@+id/layoutVoidInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/danger_red_light"
        android:padding="12dp"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Transaksi ini telah di-VOID"
            android:textColor="@color/danger_red"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVoidReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alasan: -"
            android:textColor="@color/danger_red"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Void Transaksi Button (hidden by default, only for status 00) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSheetVoid"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⚠️ Void Transaksi"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:backgroundTint="@color/danger_red"
        android:insetBottom="0dp"
        android:insetTop="0dp"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

</LinearLayout>
