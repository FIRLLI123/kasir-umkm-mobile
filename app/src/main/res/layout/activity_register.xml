<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_margin">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_tagline"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/text_body_large"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- Company Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCompanyName"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCompanyName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_company_name"
                android:inputType="textCapWords"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Owner Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_name"
                android:inputType="textPersonName|textCapWords"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/sym_action_email"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone / WhatsApp -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhone"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/ic_menu_call"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_phone"
                android:inputType="phone"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Address -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAddress"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/ic_dialog_map"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_address"
                android:inputType="textPostalAddress|textCapSentences"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="@color/text_gray"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Confirmation -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordConfirmation"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="@color/text_gray"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordConfirmation"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_password_confirmation"
                android:inputType="textPassword"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Captcha Container -->
        <LinearLayout
            android:id="@+id/layoutCaptcha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keamanan (Captcha)"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/white">

                    <ImageView
                        android:id="@+id/ivCaptcha"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshCaptcha"
                    style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:icon="@android:drawable/stat_notify_sync"
                    app:iconSize="24dp"
                    app:iconTint="@color/primary"
                    android:padding="0dp"
                    app:iconPadding="0dp" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCaptcha"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="@color/text_gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCaptcha"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Masukkan Kode Captcha"
                    android:inputType="textCapCharacters|textNoSuggestions"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="@color/text_dark" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.KasirUmkm.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:text="@string/btn_register"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Login Redirect Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_already_have_account"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/text_body_medium" />

            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_login_now"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_body_medium"
                android:textStyle="bold"
                android:paddingStart="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
