<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_page">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close"
            app:tint="@color/text_dark" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tambah Produk"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/spacing_sm" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <!-- Section 1: Informasi Produk -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Produk"
                android:textColor="@color/text_dark"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Kode Produk -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCode"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_barcode_scan"
                app:endIconTint="@color/primary"
                app:endIconContentDescription="Scan Barcode">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Kode Produk"
                    android:inputType="text"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nama Produk -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Nama Produk"
                    android:inputType="textPersonName"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Baris Unit & Stok -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUnit"
                    style="@style/Widget.KasirUmkm.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUnit"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="Satuan (e.g. pcs, bks)"
                        android:inputType="text"
                        android:textSize="@dimen/text_body_large" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilStock"
                    style="@style/Widget.KasirUmkm.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStock"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="Stok Awal"
                        android:inputType="number"
                        android:textSize="@dimen/text_body_large" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Section 2: Harga & Margin -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga &amp; Margin"
                android:textColor="@color/text_dark"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Harga Modal (Cost Price) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCostPrice"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:prefixText="Rp "
                app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCostPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:hint="Harga Modal"
                    android:inputType="numberDecimal"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Harga Jual - USER (Reguler) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPriceUser"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:prefixText="Rp "
                app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix"
                app:helperText="Harga jual untuk pembeli golongan USER">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPriceUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:hint="Harga Jual - USER"
                    android:inputType="numberDecimal"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Harga Jual - FREELANCER -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPriceFreelancer"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:prefixText="Rp "
                app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix"
                app:helperText="Harga jual untuk pembeli golongan FREELANCER">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPriceFreelancer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:hint="Harga Jual - FREELANCER"
                    android:inputType="numberDecimal"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Harga Jual - GROSIR -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPriceGrosir"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                app:prefixText="Rp "
                app:prefixTextAppearance="@style/TextAppearance.KasirUmkm.Prefix"
                app:helperText="Harga jual untuk pembeli golongan GROSIR">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPriceGrosir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:hint="Harga Jual - GROSIR"
                    android:inputType="numberDecimal"
                    android:textSize="@dimen/text_body_large" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.KasirUmkm.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:text="@string/simpan" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
