<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Card Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvRowNumber"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Produk #1"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Hapus Baris"
                app:tint="@color/danger_red" />
        </LinearLayout>

        <!-- Pilih Produk + Scan Icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilProduct"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="Pilih Produk (Wajib)"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp">
                <AutoCompleteTextView
                    android:id="@+id/actvProduct"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScan"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_barcode_scan"
                app:iconTint="@color/primary"
                app:iconSize="24dp"
                app:iconPadding="0dp"
                android:contentDescription="Scan Barcode" />
        </LinearLayout>

        <!-- Baris Info Stok -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCurrentStock"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCurrentStock"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Stok Saat Ini"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="false"
                    android:enabled="false"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilQtyAdd"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQtyAdd"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Qty Tambah (Wajib)"
                    android:inputType="number"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFinalStock"
                style="@style/Widget.KasirUmkm.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFinalStock"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:hint="Stok Akhir"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="false"
                    android:enabled="false"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Catatan -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNote"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="Catatan (Opsional)"
                android:inputType="text"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
