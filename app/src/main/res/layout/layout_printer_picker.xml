<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/splash_pill_bg"
    android:backgroundTint="@color/white"
    android:padding="20dp">

    <!-- Handle line for bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/border_light"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Koneksi Printer Bluetooth"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Tutup"
            app:tint="@color/text_gray" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pastikan printer thermal sudah dipasangkan (paired) di pengaturan Bluetooth HP Anda terlebih dahulu."
        android:textColor="@color/text_gray"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <!-- State 1: Bluetooth Disabled -->
    <LinearLayout
        android:id="@+id/layoutBluetoothOff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="40sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Tidak Aktif"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Silakan aktifkan Bluetooth Anda untuk memindai printer."
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnableBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aktifkan Bluetooth"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>

    <!-- State 2: Permission Missing -->
    <LinearLayout
        android:id="@+id/layoutPermissionMissing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="40sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Izin Bluetooth Diperlukan"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aplikasi memerlukan izin akses perangkat Bluetooth terdekat untuk mencetak."
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequestPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Izinkan Akses"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>

    <!-- State 3: Device List -->
    <LinearLayout
        android:id="@+id/layoutDeviceContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PILIH PRINTER TERPASANG"
            android:textColor="@color/text_gray"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Device List View -->
        <ListView
            android:id="@+id/lvDevices"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:divider="@color/border_light"
            android:dividerHeight="1dp"
            android:scrollbars="vertical"/>

        <TextView
            android:id="@+id/tvEmptyDevices"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="Tidak ditemukan printer yang terpasang (paired).\nPasangkan printer Anda di Pengaturan Bluetooth HP."
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- Selected Printer Status Indicator -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectedPrinter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/background_page"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖨️"
                    android:textSize="22sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvActivePrinterName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Printer Name"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvActivePrinterAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:11:22:33:44:55"
                        android:textColor="@color/text_gray"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktif"
                    android:textColor="@color/success_green"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/splash_pill_bg"
                    android:backgroundTint="#FFF0FDF4"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Hapus Printer"
                android:textColor="@color/danger_red"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestPrint"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Uji Coba Cetak"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pickerProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        android:layout_marginTop="16dp"/>
</LinearLayout>
