<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Warning Icon & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⚠️"
            android:textSize="22sp"
            android:background="@color/yellow_warning_light" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alasan Void"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wajib diisi untuk audit"
                android:textColor="@color/text_light"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Invoice Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/danger_red_light"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Invoice: "
            android:textColor="@color/danger_red"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvVoidInvoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INV/xxxx"
            android:textColor="@color/danger_red"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Void Reason Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilVoidReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterEnabled="true"
        app:counterMaxLength="200"
        app:errorEnabled="true"
        app:hintTextColor="@color/primary"
        app:boxStrokeColor="@color/primary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVoidReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tulis alasan pembatalan (min. 10 karakter)"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="5"
            android:maxLength="200"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoidReasonCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Batal"
            android:textColor="@color/text_gray"
            app:backgroundTint="@color/white"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoidReasonContinue"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Lanjutkan"
            android:textColor="@color/white"
            app:backgroundTint="@color/danger_red"
            app:cornerRadius="8dp"
            android:enabled="false" />
    </LinearLayout>
</LinearLayout>
