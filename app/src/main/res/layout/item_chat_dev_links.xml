<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <!-- Spacer agar sejajar dengan bubble AI (skip avatar space = 32dp + 8dp margin) -->
    <View
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:layout_marginEnd="8dp" />

    <!-- Tombol-tombol link -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Portfolio -->
        <TextView
            android:id="@+id/btnDevPortfolio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_portfolio"
            android:text="🌐  Portfolio"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- WhatsApp -->
        <TextView
            android:id="@+id/btnDevWhatsApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_wa"
            android:text="💬  WhatsApp"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
