<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_page">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close"
            app:tint="@color/text_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detail Produk"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/spacing_sm" />

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit"
            app:tint="@color/primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <!-- Product Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_horizontal">

                    <!-- Large Emoji Avatar -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primary_light"
                        android:layout_marginBottom="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tvEmoji"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textSize="32sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark"
                        android:textSize="@dimen/text_headline_medium"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvBadgeStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="AKTIF"
                        android:textColor="@color/primary"
                        android:background="@drawable/badge_primary_bg"
                        android:textSize="@dimen/text_body_medium"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/spacing_sm" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stock & Cost Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Code -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kode Produk" android:textColor="@color/text_light" android:textSize="@dimen/text_body_medium" />
                    <TextView android:id="@+id/tvCode" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_dark" android:textSize="@dimen/text_body_large" android:textStyle="bold" android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Stock & Unit -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Stok Saat Ini" android:textColor="@color/text_light" android:textSize="@dimen/text_body_medium" />
                    <TextView android:id="@+id/tvStock" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_dark" android:textSize="@dimen/text_body_large" android:textStyle="bold" android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Cost Price -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Harga Modal (Cost Price)" android:textColor="@color/text_light" android:textSize="@dimen/text_body_medium" />
                    <TextView android:id="@+id/tvCostPrice" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_dark" android:textSize="@dimen/text_body_large" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pricing & Margins Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Jual &amp; Margin Keuntungan"
                android:textColor="@color/text_dark"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- USER (Retail) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Harga USER (Reguler)" android:textColor="@color/text_dark" android:textStyle="bold" android:textSize="@dimen/text_body_large" />
                            <TextView android:id="@+id/tvMarginUser" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/primary" android:textSize="@dimen/text_body_medium" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvPriceUser" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_dark" android:textSize="@dimen/text_headline_small" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- FREELANCER -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Harga FREELANCER" android:textColor="@color/orange_primary" android:textStyle="bold" android:textSize="@dimen/text_body_large" />
                            <TextView android:id="@+id/tvMarginFreelancer" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/orange_primary" android:textSize="@dimen/text_body_medium" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvPriceFreelancer" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_dark" android:textSize="@dimen/text_headline_small" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- GROSIR -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Harga GROSIR" android:textColor="@color/purple_primary" android:textStyle="bold" android:textSize="@dimen/text_body_large" />
                            <TextView android:id="@+id/tvMarginGrosir" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/purple_primary" android:textSize="@dimen/text_body_medium" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvPriceGrosir" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_dark" android:textSize="@dimen/text_headline_small" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.KasirUmkm.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/hapus" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
