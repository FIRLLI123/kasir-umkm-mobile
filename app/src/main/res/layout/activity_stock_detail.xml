<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="@dimen/page_margin"
            android:background="@color/white"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="?attr/homeAsUpIndicator"
                android:contentDescription="Kembali"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detail Stok"
                android:textColor="@color/text_dark"
                android:textSize="@dimen/text_headline_medium"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_margin"
                android:paddingBottom="80dp">

                <!-- Product Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/hero_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <!-- Product Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Emoji Circle -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardCornerRadius="28dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="@color/primary_light">

                                <TextView
                                    android:id="@+id/tvEmoji"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:textSize="28sp" />
                            </androidx.cardview.widget.CardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_lg">

                                <TextView
                                    android:id="@+id/tvProductName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_headline_small"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProductCode"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_gray"
                                    android:textSize="@dimen/text_body_medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border_light"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:layout_marginBottom="@dimen/spacing_lg" />

                        <!-- Stock Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <!-- Current Stock -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Stok Saat Ini"
                                    android:textColor="@color/text_gray"
                                    android:textSize="@dimen/text_body_medium" />

                                <TextView
                                    android:id="@+id/tvCurrentStock"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="48dp"
                                android:background="@color/border_light"
                                android:layout_gravity="center" />

                            <!-- Unit -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Satuan"
                                    android:textColor="@color/text_gray"
                                    android:textSize="@dimen/text_body_medium" />

                                <TextView
                                    android:id="@+id/tvUnit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PCS"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_headline_medium"
                                    android:textStyle="bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="48dp"
                                android:background="@color/border_light"
                                android:layout_gravity="center" />

                            <!-- Status -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Status"
                                    android:textColor="@color/text_gray"
                                    android:textSize="@dimen/text_body_medium" />

                                <TextView
                                    android:id="@+id/tvStockStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mutation History Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📋 Riwayat Mutasi Stok"
                        android:textColor="@color/text_dark"
                        android:textSize="@dimen/text_title_medium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFilterDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 Filter"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_body_medium"
                        android:textStyle="bold"
                        android:padding="@dimen/spacing_sm"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>

                <!-- Date Range Indicator -->
                <TextView
                    android:id="@+id/tvDateRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_light"
                    android:textSize="@dimen/text_body_medium"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:visibility="gone" />

                <!-- Mutation Timeline List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMutations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false" />

                <!-- Empty Mutations -->
                <LinearLayout
                    android:id="@+id/layoutEmptyMutations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/spacing_xxxl"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum ada riwayat mutasi"
                        android:textColor="@color/text_gray"
                        android:textSize="@dimen/text_body_large"
                        android:layout_marginTop="@dimen/spacing_md" />
                </LinearLayout>

                <!-- Loading -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone"
                    android:layout_marginTop="@dimen/spacing_xxl" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- FAB: Adjust Stock -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAdjust"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/page_margin"
        android:text="Sesuaikan Stok"
        android:textColor="@color/white"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialComponents.FloatingActionButton" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
