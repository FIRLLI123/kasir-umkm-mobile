<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/page_margin"
            android:paddingEnd="@dimen/page_margin"
            android:background="@color/white"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="?attr/homeAsUpIndicator"
                android:contentDescription="@string/cd_close"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/backup_activity_title"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_backup_subtitle"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_margin">

                <!-- Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/card_padding"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="28sp"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/backup_info_desc"
                            android:textColor="@color/text_gray"
                            android:textSize="@dimen/text_body_medium"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section 1: Sales / Transactions -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#EFF6FF"
                                android:textColor="#2563EB"
                                android:text="🧾"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_sales_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_sales_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportSales"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="@color/primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section 2: Products -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#F0FDF4"
                                android:textColor="#16A34A"
                                android:text="📦"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_products_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_products_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportProducts"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="@color/primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section 3: Customers -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="@dimen/spacing_xl">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#FAF5FF"
                                android:textColor="#7C3AED"
                                android:text="👥"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_customers_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_customers_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportCustomers"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="@color/primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── SECTION LAPORAN ANALITIK ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Laporan Analitik"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="#FED7AA"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FFFBF5"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#FFF7ED"
                                android:text="📅"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_sales_summary_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_sales_summary_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportSalesSummary"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="#EA580C" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Laporan Margin -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="#99F6E4"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#F0FDFB"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#CCFBF1"
                                android:text="💹"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_margin_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_margin_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportMargin"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="#0D9488" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ranking Produk Terlaris -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="#C4B5FD"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FAF5FF"
                    android:layout_marginBottom="@dimen/spacing_xl">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_quick_prompt"
                                android:backgroundTint="#EDE9FE"
                                android:text="🏆"
                                android:textSize="22sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_top_products_title"
                                    android:textColor="@color/text_dark"
                                    android:textSize="@dimen/text_body_large"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/report_top_products_desc"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExportTopProducts"
                            style="@style/Widget.KasirUmkm.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/btn_export_now"
                            app:icon="@drawable/ic_chat_ai"
                            app:iconTint="@color/white"
                            android:backgroundTint="#7C3AED" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Progress Overlay -->
    <FrameLayout
        android:id="@+id/layoutProgressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="24dp"
            android:background="@drawable/bg_quick_prompt"
            android:backgroundTint="@color/white">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/tvProgressMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/memuat"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
