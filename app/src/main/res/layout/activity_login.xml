<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/page_margin">

        <!-- Spacer Top -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Logo -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="@dimen/logo_radius"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/primary"
            android:layout_marginBottom="@dimen/spacing_lg">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:src="@drawable/airin"
                android:textSize="38sp" />
        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/text_headline_medium"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_tagline"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/text_body_large"
            android:layout_marginBottom="@dimen/spacing_xxxl" />

        <!-- Email Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:startIconDrawable="@android:drawable/sym_action_email"
            app:startIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.KasirUmkm.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xxl"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="@color/text_gray"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_gray">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textSize="@dimen/text_body_large"
                android:textColor="@color/text_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.KasirUmkm.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:text="@string/btn_login"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Register Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_no_account"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/text_body_medium" />

            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_register_now"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_body_medium"
                android:textStyle="bold"
                android:paddingStart="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Loading Indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Device Lock Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/device_lock_info"
            android:textColor="@color/text_light"
            android:textSize="@dimen/text_caption"
            android:drawablePadding="@dimen/spacing_xs"
            android:gravity="center" />

        <!-- Version Name -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="@color/text_light"
            android:textSize="@dimen/text_caption"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center" />

        <!-- Spacer Bottom -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="2" />

    </LinearLayout>
</ScrollView>
