<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_page">

    <!-- Header Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/page_margin"
        android:paddingEnd="@dimen/page_margin"
        android:background="@color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <!-- Profile Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Avatar -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primary">
                        <TextView
                            android:id="@+id/tvAvatarInitials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Administrator"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="admin@mail.com"
                            android:textColor="@color/text_gray"
                            android:textSize="@dimen/text_body_medium"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Settings Options Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Option 1: Profile -->
                    <LinearLayout
                        android:id="@+id/layoutOptionProfile"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Profil Saya"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                    <!-- Option 1.5: Langganan & Pembayaran -->
                    <LinearLayout
                        android:id="@+id/layoutOptionSubscription"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💳"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/subscription_menu"
                                android:textColor="@color/text_dark"
                                android:textSize="@dimen/text_body_large" />
                            
                            <TextView
                                android:id="@+id/tvSubscriptionMenuSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status paket: Trial"
                                android:textColor="@color/text_gray"
                                android:textSize="12dp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSubscriptionBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trial"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="@drawable/bg_badge_rounded"
                            android:textColor="@color/blue_info"
                            android:backgroundTint="@color/blue_info_light"
                            android:layout_marginEnd="8dp" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                    <!-- Option 2: Printer Bluetooth -->
                    <LinearLayout
                        android:id="@+id/layoutOptionPrinter"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🖨️"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Koneksi Printer Bluetooth"
                                android:textColor="@color/text_dark"
                                android:textSize="@dimen/text_body_large" />
                            
                            <TextView
                                android:id="@+id/tvSelectedPrinter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Belum diatur"
                                android:textColor="@color/text_gray"
                                android:textSize="12dp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                    <!-- Option 3: Manajemen Stok -->
                    <LinearLayout
                        android:id="@+id/layoutOptionStock"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Manajemen Stok"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                    <!-- Option 3.5: Manajemen Company (SUPER_ADMIN) -->
                    <LinearLayout
                        android:id="@+id/layoutOptionCompany"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:visibility="gone">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏢"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Manajemen UMKM / Company"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View 
                        android:id="@+id/dividerCompany"
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="@color/border_light"
                        android:visibility="gone" />

                    <!-- Option 3.6: Manajemen User (SUPER_ADMIN) -->
                    <LinearLayout
                        android:id="@+id/layoutOptionUser"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:visibility="gone">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:id="@+id/tvOptionUserText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Manajemen Pengguna / User"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View 
                        android:id="@+id/dividerUser"
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="@color/border_light"
                        android:visibility="gone" />

                    <!-- Option 3.7: Backup & Export -->
                    <LinearLayout
                        android:id="@+id/layoutOptionBackup"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💾"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_backup_title"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/menu_backup_subtitle"
                            android:textColor="@color/text_gray"
                            android:textSize="@dimen/text_body_medium"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_light"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="@color/border_light" />

                    <!-- Option 4: Info Aplikasi -->
                    <LinearLayout
                        android:id="@+id/layoutOptionInfo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/card_padding"
                        android:paddingEnd="@dimen/card_padding"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ℹ️"
                            android:textSize="20sp"
                            android:layout_marginEnd="@dimen/spacing_md" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Informasi Aplikasi"
                            android:textColor="@color/text_dark"
                            android:textSize="@dimen/text_body_large" />
                        
                        <TextView
                            android:id="@+id/tvAppVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="v1.0.0"
                            android:textColor="@color/text_gray"
                            android:textSize="@dimen/text_body_medium" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.KasirUmkm.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Keluar" />

            <!-- Progress Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
