<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0F172A">

    <!-- ===== TOOLBAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_toolbar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="?attr/homeAsUpIndicator"
            android:contentDescription="Kembali"
            android:clickable="true"
            android:focusable="true"
            android:tint="@android:color/white"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="8dp" />

        <!-- AI Avatar in toolbar -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/airin"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Title + Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tanya Kak Airin"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Online"
                android:textColor="#FF94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Clear chat button -->
        <ImageButton
            android:id="@+id/btnClearChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FF94A3B8"
            android:contentDescription="Hapus percakapan" />

    </LinearLayout>

    <!-- ===== CHAT LIST ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <!-- ===== EMPTY STATE ===== -->
        <ScrollView
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingVertical="32dp">

                <!-- Big AI Icon -->
                <LinearLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/airin"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Halo! Aku Airin, Kasir Senior"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tenang yaa, Airin di sini siap bantu jawab pertanyaan dan menemani bisnis kamu setiap hari 💕"
                    android:textColor="#FF94A3B8"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coba tanya ini:"
                    android:textColor="#FF64748B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Quick Prompt Chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/chipPrompt1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_prompt"
                        android:text="💡  Jelaskan fitur aplikasi ini"
                        android:textColor="#FFCBD5E1"
                        android:textSize="13sp"
                        android:padding="14dp"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipPrompt2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_prompt"
                        android:text="🧾  Bagaimana cara input penjualan?"
                        android:textColor="#FFCBD5E1"
                        android:textSize="13sp"
                        android:padding="14dp"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipPrompt3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_prompt"
                        android:text="📊  Bagaimana cara melihat laporan?"
                        android:textColor="#FFCBD5E1"
                        android:textSize="13sp"
                        android:padding="14dp"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipPrompt4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_prompt"
                        android:text="📦  Bagaimana cara cek stok?"
                        android:textColor="#FFCBD5E1"
                        android:textSize="13sp"
                        android:padding="14dp"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chipPrompt5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_prompt"
                        android:text="👨‍💻  Siapa sih yang bikin aplikasi ini? Yuk intip!"
                        android:textColor="#FFCBD5E1"
                        android:textSize="13sp"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Spacer bawah -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- ===== INPUT AREA ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF0F172A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:hint="Ketik pesan..."
            android:textColorHint="#FF64748B"
            android:textColor="#FFCBD5E1"
            android:textSize="14sp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:imeOptions="actionSend"
            android:layout_marginEnd="10dp" />

        <!-- Send Button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_send"
            app:backgroundTint="@color/primary"
            app:tint="@color/white"
            app:fabSize="mini"
            app:elevation="4dp"
            android:contentDescription="Kirim pesan" />

    </LinearLayout>

</LinearLayout>
