<?xml version="1.0" encoding="utf-8"?>
<!--
    item_onboarding_slide.xml
    Layout untuk 1 slide. Konten ini di-scroll oleh ViewPager2.
    Bottom 200dp dikosongkan untuk space overlay tombol/dot.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/slideRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="64dp"
        android:paddingBottom="220dp"
        android:paddingLeft="28dp"
        android:paddingRight="28dp"
        android:gravity="center_horizontal">

        <!-- Airin Chibi Image -->
        <ImageView
            android:id="@+id/ivAirin"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="24dp"
            android:contentDescription="Airin" />

        <!-- AI Badge — hanya tampil di slide 2 -->
        <LinearLayout
            android:id="@+id/layoutAiBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_ai_badge"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨"
                android:textSize="13sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Didukung kecerdasan AI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5B21B6" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="12dp" />

        <!-- Container for description + special content -->
        <LinearLayout
            android:id="@+id/contentArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Normal description text -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <!-- INFO CARD — Slide 2: Kemampuan Airin -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layoutInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F8FAFB"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aku bisa bantu kamu untuk:"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="14dp" />

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chat &amp; tanya jawab"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tanya apa saja, kapan saja"
                                android:textSize="12sp"
                                android:textColor="#64748B" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analisis laporan &amp; omzet"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Insight bisnis real-time"
                                android:textSize="12sp"
                                android:textColor="#64748B" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saran bisnis personal"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Disesuaikan dengan usaha kamu"
                                android:textSize="12sp"
                                android:textColor="#64748B" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧾"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bantu input &amp; cek transaksi"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Akurat dan cepat"
                                android:textSize="12sp"
                                android:textColor="#64748B" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CHIPS — Slide 3: Fitur Aplikasi -->
            <LinearLayout
                android:id="@+id/layoutChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Row 1 chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="🛒  POS Kasir"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📷  Scan Barcode"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Row 2 chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="📦  Stok Produk"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📈  Dashboard"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Row 3 chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="🖨  Struk Thermal"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="🤖  Chat AI"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F766E"
                        android:background="@drawable/bg_feature_chip"
                        android:padding="10dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Stat row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_chip"
                        android:padding="10dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Omzet"
                            android:textSize="10sp"
                            android:textColor="#64748B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Real-time"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#0F766E" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_chip"
                        android:padding="10dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Margin"
                            android:textSize="10sp"
                            android:textColor="#64748B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Akurat"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#0F766E" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_chip"
                        android:padding="10dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer"
                            android:textSize="10sp"
                            android:textColor="#64748B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tersimpan"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#0F766E" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- WARNING CARD — Slide 4: Peringatan imut dari Airin -->
            <LinearLayout
                android:id="@+id/layoutWarningCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Subtitle imut -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Airin udah mau ngajarin kamu, tapi ada 3 hal yang bikin Airin beneran marah ya~ 🫰"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp" />

                <!-- Card peringatan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_warning_card"
                    android:padding="18dp">

                    <!-- Warning 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😤"
                            android:textSize="20sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jangan lupa update stok!"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#BE123C" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kalau kosong terus, Airin ikut sedih loh~ 🥺"
                                android:textSize="11sp"
                                android:textColor="#9F1239" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Warning 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🙅"
                            android:textSize="20sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jangan lupa untuk tanya Airin dari fitur chat!"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#BE123C" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tanya Airin dulu sebelum bingung sendiri ya! 😤"
                                android:textSize="11sp"
                                android:textColor="#9F1239" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Warning 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💢"
                            android:textSize="20sp"
                            android:layout_marginEnd="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jangan abaikan notifikasi stok!"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#BE123C" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Airin udah capek-capek ingetin, masa diabaikan? 😩"
                                android:textSize="11sp"
                                android:textColor="#9F1239" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- Catatan kaki imut -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tapi tenang~ Airin tetep selalu hadir kok, asal janji ya! 🤞"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:gravity="center"
                    android:fontFamily="sans-serif-italic"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
