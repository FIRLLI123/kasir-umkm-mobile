<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Bluetooth for thermal printer -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />

    <!-- Camera for barcode scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Storage for CSV export (legacy devices) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KasirUmkm2"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Splash (Launcher) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KasirUmkm2.Login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.KasirUmkm2.Login" />

        <!-- Register -->
        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.KasirUmkm2.Login" />

        <!-- Onboarding Guide Tour -->
        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.KasirUmkm2.Login" />

        <!-- Subscription Plan Selector -->
        <activity
            android:name=".ui.SubscriptionActivity"
            android:exported="false"
            android:label="@string/subscription_title" />

        <!-- QRIS Payment Gateway -->
        <activity
            android:name=".ui.PaymentActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:label="@string/payment_title" />

        <!-- Main (BottomNav Host) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- POS -->
        <activity
            android:name=".ui.POSActivity"
            android:exported="false"
            android:theme="@style/Theme.KasirUmkm2.POS" />

        <!-- Customer -->
        <activity android:name=".ui.CustomerListActivity" android:exported="false" />
        <activity android:name=".ui.CustomerFormActivity" android:exported="false" />
        <activity android:name=".ui.CustomerDetailActivity" android:exported="false" />

        <!-- Product -->
        <activity android:name=".ui.ProductListActivity" android:exported="false" />
        <activity android:name=".ui.ProductFormActivity" android:exported="false" />
        <activity android:name=".ui.ProductDetailActivity" android:exported="false" />
        <activity android:name=".ui.ProductBulkActivity" android:exported="false" />
        <activity android:name=".ui.ProductImportActivity" android:exported="false" />

        <!-- Stock -->
        <activity android:name=".ui.StockActivity" android:exported="false" />
        <activity android:name=".ui.StockDetailActivity" android:exported="false" />
        <activity android:name=".ui.StockBulkInActivity" android:exported="false" />

        <!-- Checkout & Success -->
        <activity android:name=".ui.CheckoutActivity" android:exported="false" />
        <activity android:name=".ui.SuccessActivity" android:exported="false" />
        <activity android:name=".ui.SalesHistoryActivity" android:exported="false" />

        <!-- Settings -->
        <activity android:name=".ui.ProfileActivity" android:exported="false" />

        <!-- Company Management -->
        <activity android:name=".ui.CompanyActivity" android:exported="false" />
        <activity android:name=".ui.CompanyFormActivity" android:exported="false" />

        <!-- User Management -->
        <activity android:name=".ui.UserActivity" android:exported="false" />
        <activity android:name=".ui.UserFormActivity" android:exported="false" />

        <!-- AI Chatbot -->
        <activity android:name=".ui.ChatActivity" android:exported="false" />

        <!-- Backup & Export -->
        <activity android:name=".ui.BackupActivity" android:exported="false" />

        <!-- Portrait Barcode Scanner -->
        <activity
            android:name=".ui.PortraitCaptureActivity"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/zxing_CaptureTheme"
            android:exported="false" />

        <!-- File Provider for sharing CSV files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.kasirumkm2.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>